# Database
DB_URL=sqlite:///./redbyte.db

# Auth
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_SECONDS=604800
# 7 days

# API
API_ADDRESS=SERVER_IP
API_PORT=8000

# CORS
ALLOWED_ORIGINS=https://SERVER_IP:3000,https://redbyteweb.duckdns.org

# Enpoint
ENROLLMENT_TOKEN_EXPIRE_SECONDS=120

# TCP Server
TCP_SERVER_HOST=SERVER_IP
TCP_SERVER_PORT=9000
