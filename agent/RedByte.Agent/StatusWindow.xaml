<Window x:Class="RedByte.Agent.StatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RedByte Status" Height="500" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" 
        Background="White"
        Icon="./Assets/icon.ico">
    <StackPanel Margin="20" VerticalAlignment="Center" HorizontalAlignment="Center">
        <Image Source="./Assets/redbyte-logo.png" Height="40" Margin="0,0,0,40" Stretch="Uniform"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
            <Ellipse Width="14" Height="14" Fill="#28a745" Margin="0,0,10,0" VerticalAlignment="Center"/>
            <TextBlock Text="Successfully Connected" FontSize="20" FontWeight="Bold" Foreground="#333333" VerticalAlignment="Center"/>
        </StackPanel>
        <TextBlock Text="You are connected to RedByte." FontSize="15" Foreground="#666666" HorizontalAlignment="Center" Margin="0,0,0,5"/>
        <TextBlock Text="Network traffic is actively being captured and analyzed." FontSize="14" Foreground="#666666" HorizontalAlignment="Center" Margin="0,0,0,40"/>
        <Button Content="Hide" Height="35" Width="250" Background="#f5f5f5" Foreground="#333333" FontSize="14" FontWeight="Bold" BorderThickness="1" BorderBrush="#cccccc" Click="HideButton_Click"/>
    </StackPanel>
</Window>