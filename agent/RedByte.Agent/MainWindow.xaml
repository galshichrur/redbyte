<Window x:Class="RedByte.Agent.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RedByte Agent" Height="500" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" 
        Background="White"
        Icon="./Assets/icon.ico">
    <StackPanel Margin="20" VerticalAlignment="Center" HorizontalAlignment="Center">
        <Image Source="./Assets/redbyte-logo.png" Height="40" Margin="0,0,0,30" Stretch="Uniform"/>
        <TextBlock Text="Connect Your Computer" FontSize="18" FontWeight="Bold" Foreground="#333333" HorizontalAlignment="Center" Margin="0,0,0,10"/>
        <TextBlock Text="Enter your enrollment code from the dashboard." FontSize="14" Foreground="#666666" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20"/>
        <TextBox x:Name="EnrollmentCodeTextBox" Height="30" Width="250" FontSize="14" Margin="0,0,0,20" Padding="5,0"/>
        <Button Content="Submit" Height="35" Width="250" Background="#cf3f50" Foreground="White" FontSize="14" FontWeight="Bold" BorderThickness="0" Click="SubmitButton_Click"/>
        <TextBlock x:Name="StatusTextBlock" Text="" FontSize="14" Foreground="#cf3f50" HorizontalAlignment="Center" Margin="0,15,0,0" Visibility="Collapsed"/>
    </StackPanel>
</Window>